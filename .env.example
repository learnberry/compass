# ─── Web Push (VAPID) ────────────────────────────────────────────────
# Generate a key pair with:  pnpm vapid
# Then copy the values below. The public key must be set in BOTH the
# server-only and NEXT_PUBLIC_ variables (same value).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Same value as VAPID_PUBLIC_KEY — exposed to the browser so it can subscribe.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ─── Database (Supabase / Postgres) ──────────────────────────────────
# Server-only service-role key — used by the data layer (lib/db/supabase).
# NEVER expose this to the browser; it bypasses Row Level Security.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ─── Supabase Auth (browser, Google OAuth) ───────────────────────────
# Publishable/anon key — safe to expose; only grants the limited anon role.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Comma-separated allowlist of Google emails permitted to sign in.
AUTH_ALLOWED_EMAILS=you@example.com

# ─── Apple Health ingest ─────────────────────────────────────────────
# Shared secret guarding POST /api/health/ingest (the iOS Shortcut posts
# Apple Health data here with `Authorization: Bearer <token>`). The endpoint
# fails closed when this is unset. Generate one with: openssl rand -hex 32
HEALTH_INGEST_TOKEN=
