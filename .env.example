# ─── Web Push (VAPID) ────────────────────────────────────────────────
# Generate a key pair with:  pnpm vapid
# Then copy the values below. The public key must be set in BOTH the
# server-only and NEXT_PUBLIC_ variables (same value).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Same value as VAPID_PUBLIC_KEY — exposed to the browser so it can subscribe.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ─── Database ────────────────────────────────────────────────────────
# Local SQLite file. Swap the repository (lib/db/repository.ts) to move
# off SQLite — see the README "Switching to Supabase" section.
DATABASE_PATH=./data/compass.db
